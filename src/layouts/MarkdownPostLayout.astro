---
import BaseLayout from "./BaseLayout.astro"
const { frontmatter } = Astro.props
---

<BaseLayout pageTitle={frontmatter.title}>
    <meta charset="utf-8" />

    <article
        style="max-width: 750px; margin: 2rem auto; padding: 1.5rem; background-color: #f9f9f9; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); font-family: 'Inter', sans-serif; line-height: 1.6;">
        <header style="text-align: center; margin-bottom: 1.5rem;">
            <h1 style="margin-bottom: 0.5rem; color: #222;">
                {frontmatter.title}
            </h1>
            <p style="color: #666; font-size: 0.9rem;">
                Published on <strong
                    >{frontmatter.pubDate.toString().slice(0, 10)}</strong
                >
            </p>
            <p style="font-style: italic; color: #444;">
                {frontmatter.description}
            </p>
            <p style="margin-top: 0.5rem; color: #777;">
                Written by <strong>{frontmatter.author}</strong>
            </p>
        </header>

        <div style="text-align: center; margin: 1.5rem 0;">
            <img
                src={frontmatter.image.url}
                width="100%"
                style="max-width: 500px; border-radius: 6px; box-shadow: 0 1px 6px rgba(0,0,0,0.1);"
                alt={frontmatter.image.alt}
            />
        </div>

        <section style="color: #333; font-size: 1rem;">
            <slot />
        </section>
    </article>
</BaseLayout>
